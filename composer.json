{
    "name": "avaibooksports/omnipay-paypal-checkout",
    "type": "library",
    "description": "PayPal Checkout (Orders API v2) driver for the Omnipay payment processing library",
    "keywords": [
        "gateway",
        "merchant",
        "omnipay",
        "pay",
        "payment",
        "paypal",
        "checkout",
        "rest",
        "v2",
        "purchase"
    ],
    "homepage": "https://github.com/AvaiBookSports/omnipay-paypal-checkout",
    "license": "MIT",
    "authors": [
        {
            "name": "AvaiBook Sports",
            "email": "dev@avaibooksports.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Omnipay\\PayPalCheckout\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Omnipay\\PayPalCheckout\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "omnipay/common": "^3.2",
        "paypal/paypal-server-sdk": "^2.0",
        "symfony/http-client": "^7.4"
    },
    "require-dev": {
        "omnipay/tests": "^4.1",
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "test": "phpunit",
        "check": [
            "@cs-check",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
